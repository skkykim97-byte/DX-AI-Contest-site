# 서버 포트 (기본값: 3000)
PORT=3000

# 관리자 인증 비밀번호 (X-Admin-Token 헤더와 비교, 기본값: admin123)
ADMIN_PASSWORD=admin123

# (선택) 데이터 영구 저장용 Upstash Redis REST 정보.
# 두 값을 모두 설정하면 제출물/투표/상태가 서버 재시작·재배포 후에도 유지됩니다.
# 설정하지 않으면 로컬 JSON 파일에 저장됩니다(무료 호스팅에서는 재시작 시 초기화될 수 있음).
# Upstash(https://upstash.com)에서 무료 Redis DB 생성 후 REST URL/TOKEN 복사.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
